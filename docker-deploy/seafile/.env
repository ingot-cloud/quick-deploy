#################################
# Docker compose configurations #
#################################
COMPOSE_FILE='seafile-server.yml'
COMPOSE_PATH_SEPARATOR=','

## Images
SEAFILE_IMAGE=docker-registry.ingotcloud.top/seafileltd/seafile-mc:13.0.21
SEAFILE_DB_IMAGE=docker-registry.ingotcloud.top/mariadb:10.11
SEAFILE_REDIS_IMAGE=docker-registry.ingotcloud.top/redis:8.2.0
SEAFILE_CADDY_IMAGE=docker-registry.ingotcloud.top/lucaslorentz/caddy-docker-proxy:2.12.0-alpine
SEADOC_IMAGE=docker-registry.ingotcloud.top/seafileltd/sdoc-server:2.0.9
NOTIFICATION_SERVER_IMAGE=seafileltd/notification-server:13.0.10
MD_IMAGE=seafileltd/seafile-md-server:13.0.20

## Persistent Storage
BASIC_STORAGE_PATH=/data/docker-volumes
SEAFILE_VOLUME=$BASIC_STORAGE_PATH/seafile-data
SEAFILE_MYSQL_VOLUME=$BASIC_STORAGE_PATH/seafile-mysql/db
SEAFILE_CADDY_VOLUME=$BASIC_STORAGE_PATH/seafile-caddy
SEADOC_VOLUME=$BASIC_STORAGE_PATH/seadoc-data

#################################
#      Startup parameters       #
#################################
# 这个是具体访问的域名，比如分享链接和上传链接都会使用这个域名
SEAFILE_SERVER_HOSTNAME=seafile.example.com
SEAFILE_SERVER_PROTOCOL=http
TIME_ZONE=Asia/Shanghai
JWT_PRIVATE_KEY=7nNyh3c1yrTH6C65p8v/KRuSUx3uwaJ71FXKsqhM/V5ExDMmTeGHuQ==

#####################################
# Third-party service configuration #
#####################################

## Database
SEAFILE_MYSQL_DB_HOST=db
SEAFILE_MYSQL_DB_USER=seafile
SEAFILE_MYSQL_DB_PASSWORD=seafile@ingot
SEAFILE_MYSQL_DB_CCNET_DB_NAME=ccnet_db
SEAFILE_MYSQL_DB_SEAFILE_DB_NAME=seafile_db
SEAFILE_MYSQL_DB_SEAHUB_DB_NAME=seahub_db

## Cache
CACHE_PROVIDER=redis # or memcached

### Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=ingotredis

### Memcached
MEMCACHED_HOST=memcached
MEMCACHED_PORT=11211

######################################
#        Initial variables           #
# (Only valid in first-time startup) #
######################################

## Database root password, Used to create Seafile users
INIT_SEAFILE_MYSQL_ROOT_PASSWORD=seafile@ingot

## Seafile admin user
INIT_SEAFILE_ADMIN_EMAIL=admin@ingotcloud.top
INIT_SEAFILE_ADMIN_PASSWORD=123456

############################################
# Additional configurations for extensions #
############################################

## SeaDoc service
ENABLE_SEADOC=false

## Notification
ENABLE_NOTIFICATION_SERVER=false
NOTIFICATION_SERVER_URL=

## Seafile AI
ENABLE_SEAFILE_AI=false
ENABLE_FACE_RECOGNITION=false
SEAFILE_AI_LLM_TYPE=openai
SEAFILE_AI_LLM_URL=
SEAFILE_AI_LLM_KEY= # your llm key
SEAFILE_AI_LLM_MODEL=gpt-4o-mini

## Metadata server
MD_FILE_COUNT_LIMIT=100000
